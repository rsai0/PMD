{
    "description": "optimum | Transfer learning and multi-task; cloud property retrieval [CLTYPE, CLOT, CLTT, CLTH, CLER_23]",
    "random_seed": 666666,
    "device": "cuda", // cpu or cuda
    "is_remove": false,
    "out_dir": "./outputs/", // Cloud property output folder
    "load_data": {
        "name": "load_dataV2",
