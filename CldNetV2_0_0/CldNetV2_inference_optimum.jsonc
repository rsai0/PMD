        "mask_delete": true,
        "mask_ratio": {
            "W": -1.0,
            "O": 1.0
        }
    },
    "SOZ": 65.0, // Sun zenith angle threshold
    "endpoint": true,
    "kf_idx": 1,
    "checkpoint1": {
        "W": {
            "CLER_23": "./models/202310260800WCLER_1_checkpoint_best.pth"
        },
        "O": {
            "CLER_23": "./models/202312060800OCLER_1_checkpoint_best.pth"
        }
    },
    "checkpoint2": {
        "W": "./models/202310260900W_1_checkpoint_best.pth",
        "O": "./models/202312060900O_1_checkpoint_best.pth"
    },
    "is_DataParallel": false,
    "batch_size": 1,
    "hw": [
        5,
        5
    ],
    "target_name": [
        "CLTYPE",
        "CLOT",
        "CLTT",
        "CLTH",
        "CLER_23"
    ],
    "logging": {
        "mode": "a+",
        "setLevel": 20,
        "file_formatter": {
            "fmt": "%(asctime)s-%(levelname)s: %(message)s",
            "datefmt": "%Y-%m-%d %H:%M:%S %p"
        },
        "terminal_formatter": {
            "fmt": "%(name)s-%(levelname)s %(asctime)s: %(message)s",
            "datefmt": "%Y-%m-%d %H:%M:%S %p"
        }
    }
}