            "vr_file": "./models/value_range.csv",
            "Cld_Vars": [
                "CLTYPE",
                "CLOT",
                "CLTT",
                "CLTH",
                "CLER_23"
            ],
            "add_vars": {
                "W": [
                    "SAZ",
                    "SAA",
                    "SOZ",
                    "SOA"
                ]
            },
            "Bidx": [
                0,
